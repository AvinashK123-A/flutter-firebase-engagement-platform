<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>Engagement Platform</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>flutter_firebase_engagement</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(FLUTTER_BUILD_NAME)</string>
    <key>CFBundleVersion</key>
    <string>$(FLUTTER_BUILD_NUMBER)</string>

    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
    </dict>

    <!-- ==================== PERMISSIONS ==================== -->
    <key>NSFaceIDUsageDescription</key>
    <string>Engagement Platform uses Face ID for secure authentication.</string>

    <key>NSCameraUsageDescription</key>
    <string>Engagement Platform needs camera access to scan QR codes and take profile photos.</string>

    <key>NSPhotoLibraryUsageDescription</key>
    <string>Engagement Platform needs photo library access for profile pictures.</string>

    <key>NSUserNotificationsUsageDescription</key>
    <string>Engagement Platform sends personalized notifications and engagement messages.</string>

    <!-- ==================== BACKGROUND MODES ==================== -->
    <key>UIBackgroundModes</key>
    <array>
        <string>fetch</string>
        <string>remote-notification</string>
        <string>processing</string>
    </array>

    <!-- ==================== URL SCHEMES ==================== -->
    <key>CFBundleURLTypes</key>
    <array>
        <!-- App custom scheme -->
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>CFBundleURLName</key>
            <string>com.avinash.firebase.engagement</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>engagementapp</string>
            </array>
        </dict>
        <!-- Google Sign-In -->
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>CFBundleURLName</key>
            <string>REVERSED_CLIENT_ID</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>com.googleusercontent.apps.YOUR_REVERSED_CLIENT_ID</string>
            </array>
        </dict>
    </array>

    <!-- Associated domains for Firebase Dynamic Links and App Links -->
    <key>com.apple.developer.associated-domains</key>
    <array>
        <string>applinks:engagementapp.com</string>
        <string>applinks:engagementapp.page.link</string>
    </array>

    <key>FirebaseAppDelegateProxyEnabled</key>
    <false/>

    <!-- Firebase Dynamic Links -->
    <key>FirebaseDynamicLinksCustomDomains</key>
    <array>
        <string>https://engagementapp.page.link</string>
    </array>

    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
    </array>

    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>

    <key>CADisableMinimumFrameDurationOnPhone</key>
    <true/>
    <key>UIApplicationSupportsIndirectInputEvents</key>
    <true/>

    <key>ENVIRONMENT</key>
    <string>$(ENVIRONMENT)</string>
    <key>API_BASE_URL</key>
    <string>$(API_BASE_URL)</string>
</dict>
</plist>
