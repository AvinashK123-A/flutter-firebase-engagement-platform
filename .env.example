# flutter-firebase-engagement-platform — Environment Config
# Copy to .env — NEVER commit real values

# API
DEV_BASE_URL=https://dev-api.engagementapp.com/v1
QA_BASE_URL=https://qa-api.engagementapp.com/v1
UAT_BASE_URL=https://uat-api.engagementapp.com/v1
PROD_BASE_URL=https://api.engagementapp.com/v1

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PROJECT_NUMBER=your-project-number
FIREBASE_WEB_API_KEY=your-web-api-key
FIREBASE_APP_ID_ANDROID=1:project_number:android:app_id
FIREBASE_SERVICE_ACCOUNT=base64-encoded-service-account-json

# Google OAuth
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# FCM
FCM_SERVER_KEY=your-fcm-server-key

# JWT
JWT_SECRET=your-jwt-secret
JWT_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=30

# Feature Flags
ENABLE_GOOGLE_SIGNIN=true
ENABLE_EMAIL_AUTH=true
ENABLE_OTP_AUTH=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_IN_APP_MESSAGING=true
ENABLE_ANALYTICS=true
ENABLE_CRASHLYTICS=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_REMOTE_CONFIG=true
ENABLE_DYNAMIC_LINKS=true

# Android Signing
ANDROID_KEYSTORE_BASE64=your-keystore-base64
ANDROID_KEY_ALIAS=your-key-alias
ANDROID_KEY_PASSWORD=your-key-password
ANDROID_STORE_PASSWORD=your-store-password

# iOS Signing
IOS_P12_BASE64=your-p12-base64
IOS_P12_PASSWORD=your-password
APPLE_TEAM_ID=YOUR_TEAM_ID

# Codecov
CODECOV_TOKEN=your-codecov-token
